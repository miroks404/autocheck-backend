APP_NAME=AutoCheckMobile Backend
APP_URL=http://localhost:8000
APP_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=dev@example.com
ENVIRONMENT=development
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg2://autocheck:autocheck@database:5432/autocheck
REDIS_URL=redis://redis:6379/0
CHECKER_STORAGE_VOLUME=autocheck_submission_storage
CHECKER_STORAGE_MOUNT=/app/storage
AI_API_KEY=
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini
# For local Ollama (free):
# AI_API_KEY=ollama
# AI_BASE_URL=http://ollama:11434/v1
# AI_MODEL=qwen2.5-coder:7b
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|192\\.168\\.\\d+\\.\\d+|10\\.\\d+\\.\\d+\\.\\d+)(:\\d+)?$
